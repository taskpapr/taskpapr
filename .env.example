# ── taskpapr environment variables ───────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database ─────────────────────────────────────────────────
#
# taskpapr uses db.js: unset DATABASE_URL → SQLite; set DATABASE_URL → PostgreSQL.
#
# ── SQLite (default — single machine, local file) ─────────────
# • Omit DATABASE_URL (or leave it commented out).
# • Optional: DB_PATH overrides the database file location.
# • Default file: <project>/data/taskpapr.db (the data/ folder is created if needed).
#
# DB_PATH=/absolute/path/to/taskpapr.db
# DB_PATH=/data/taskpapr.db
#
# ── PostgreSQL (hosted / HA — multiple app instances) ─────────
# • Set DATABASE_URL to a single shared database for every replica.
# • Sessions, Telegram bot link codes, and scheduler coordination assume one DB.
# • Bootstrap schema (safe to re-run):  DATABASE_URL=... node db-migrate.js
# • Managed/cloud Postgres often needs TLS, e.g.:
#     ?sslmode=require
#     ?sslmode=no-verify   (discouraged except dev)
#
# DATABASE_URL=postgresql://user:password@localhost:5432/taskpapr
# DATABASE_URL=postgresql://user:password@your-db.host.amazonaws.com:5432/taskpapr?sslmode=require

# ── Single-user mode ─────────────────────────────────────────
# When no auth providers are configured, single-user mode is automatic.
# The app runs without any login screen — all requests are treated as the
# local admin user. Ideal for personal local use.
#
# Set explicitly to "false" to force auth even with no providers configured.
# Set explicitly to "true" to force single-user mode even if providers are set.
# SINGLE_USER_MODE=true

# Session secret — generate a long random string for production
# e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Not required in single-user mode.
SESSION_SECRET=change-me-to-a-long-random-string

# GitHub OAuth — create at https://github.com/settings/developers
# Callback URL for local dev: http://localhost:3033/auth/github/callback
# Callback URL for production: https://yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3033/auth/github/callback

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# 1. Create a new "OAuth 2.0 Client ID" (Web application)
# 2. Add authorised redirect URI:
#    Local dev:   http://localhost:3033/auth/google/callback
#    Production:  https://yourdomain.com/auth/google/callback
# 3. Enable the "Google People API" in your project
# All three providers (GitHub, Google, OIDC) can be active simultaneously.
# Omit (or leave blank) to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3033/auth/google/callback

# Server port (default: 3033)
PORT=3033

# ── OIDC / SSO (Authentik or any standards-compliant IdP) ────
# Create an OAuth2/OpenID Connect provider in Authentik:
#   Redirect URI: https://yourdomain.com/auth/oidc/callback
#   Scopes: openid, email, profile
#
# The issuer URL for Authentik is:
#   https://<your-authentik-domain>/application/o/<application-slug>/
#
# Both GitHub and OIDC can be active simultaneously.
# Omit (or leave blank) to disable a provider.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=https://yourdomain.com/auth/oidc/callback

# Set to "true" to skip the whitelist for OIDC logins.
# Recommended when Authentik is your IdP — it is already the trust boundary.
OIDC_TRUST_IDP=true

# ── Open registration ─────────────────────────────────────────
# Controls whether the email whitelist is enforced for new sign-ups.
#
# Default behaviour (no value set):
#   - Whitelist ON  when STRIPE_SECRET_KEY is absent (self-hosted installs)
#   - Whitelist OFF when STRIPE_SECRET_KEY is set   (hosted SaaS — open registration)
#
# Override explicitly:
#   REQUIRE_WHITELIST=true   — always enforce whitelist, even on hosted installs
#   REQUIRE_WHITELIST=false  — disable whitelist, even on self-hosted installs
#
# The first user to sign up is always allowed regardless of this setting (bootstrap).
# REQUIRE_WHITELIST=

# ── Telegram notifications (optional) ────────────────────────
# Get a bot token from @BotFather on Telegram.
#
TELEGRAM_BOT_TOKEN=             # e.g. 123456:ABC-DEF...
TELEGRAM_NOTIFY_HOUR=8          # 24-hour local time for daily digest (default: 8)

# The bot's username (without @) — shown in the self-service connect UI so
# users know which bot to message. Get it from @BotFather or the bot's profile.
TELEGRAM_BOT_USERNAME=          # e.g. mytaskpaprbot

# Optional: secret token to validate incoming webhook calls from Telegram.
# Set this, then pass the same value as secret_token when registering the webhook:
#   https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://yourdomain.com/api/telegram/webhook&secret_token=<SECRET>
# If not set, the endpoint accepts all incoming requests (fine for private servers).
TELEGRAM_WEBHOOK_SECRET=        # any random string, e.g. openssl rand -hex 32

# Legacy: fallback chat ID used when a user has no personal chat ID set.
# Not needed when all users connect via the self-service flow.
TELEGRAM_CHAT_ID=               # e.g. 987654321

# Node environment
NODE_ENV=development

# ── Security limits (optional — defaults shown) ──────────────
# Per-user resource caps. Raise freely for self-hosting; lower for cautious public deployments.
# LIMIT_TASKS=2000          # max tasks per user
# LIMIT_TILES=50            # max tiles per user
# LIMIT_GOALS=50            # max goals per user
# LIMIT_BOOKMARKS=20        # max bookmarks per user

# Field length caps (characters).
# LIMIT_TITLE_LEN=500       # task title max length
# LIMIT_NAME_LEN=100        # tile / goal / bookmark name max length
# LIMIT_NOTES_LEN=50000     # task notes max length (~50KB)

# Rate limiting (requests per minute per IP).
# RATE_LIMIT_GLOBAL=300     # all routes
# RATE_LIMIT_WRITES=30      # POST /api/tasks, /api/columns, /api/goals, /api/bookmarks, /api/webhook
# RATE_LIMIT_AUTH=20        # /auth/github, /auth/oidc

# ── Stripe billing (hosted SaaS only) ────────────────────────
# Leave blank for self-hosted installs. When unset, all subscription gates
# are disabled and requireSubscription is a no-op.
#
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...       # or sk_test_... for testing
#
# Webhook signing secret — from the Stripe dashboard after adding the endpoint:
#   https://yourdomain.com/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# Price IDs — create a Solo product in the Stripe dashboard, add Monthly and
# Annual prices, then copy the price IDs here.
# STRIPE_SOLO_MONTHLY_PRICE_ID=price_...
# STRIPE_SOLO_ANNUAL_PRICE_ID=price_...
#
# Public app URL — used to build Stripe redirect URLs (success/cancel pages).
# Must match the domain you gave Stripe for webhook delivery.
# APP_URL=https://yourdomain.com
#
# Set to "true" to enable Stripe Tax (UK VAT + EU digital services tax).
# Requires Stripe Tax to be enabled in your Stripe dashboard first.
# STRIPE_TAX_ENABLED=false
